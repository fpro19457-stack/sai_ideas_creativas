generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      Role     @default(ADMIN)
  createdAt DateTime @default(now())
}

enum Role { ADMIN }

model Cliente {
  id              String    @id @default(cuid())
  email           String    @unique
  password        String
  nombre          String
  telefono        String?
  emailVerificado Boolean   @default(false)
  tokenVerif      String?
  createdAt       DateTime  @default(now())
  pedidos        Pedido[]
}
